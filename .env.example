LLM_PROVIDER=mock
MODEL_NAME=
ANTHROPIC_API_KEY=

# Required by every /api/* route (see docs/technical/04-api-design.md#authentication).
# Clients must send it back as the X-API-Key header. Unset -> all protected routes return 503.
API_KEY=

# Defaults to sqlite:///./ai_pmo_copilot.db when unset.
# For Postgres: postgresql://user:password@localhost:5432/ai_pmo_copilot
# then run: alembic upgrade head
DATABASE_URL=
