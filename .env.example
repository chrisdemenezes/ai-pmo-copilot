LLM_PROVIDER=mock

# Only used when LLM_PROVIDER=anthropic. Unset -> defaults to the model hardcoded in
# ProductionLLMProvider (src/llm/providers/production_provider.py).
MODEL_NAME=
ANTHROPIC_API_KEY=

# Required by every /api/* route (see docs/technical/04-api-design.md#authentication).
# Clients must send it back as the X-API-Key header. Unset -> all protected routes return 503.
API_KEY=

# Comma-separated list of browser origins allowed to call the API cross-origin
# (see docs/technical/04-api-design.md#cors). Unset -> no origin is allowed.
# Example: CORS_ALLOWED_ORIGINS=https://app.example.com,http://localhost:3000
CORS_ALLOWED_ORIGINS=

# Requests allowed per API key within the window below (see
# docs/technical/04-api-design.md#rate-limiting). Defaults: 60 requests / 60 seconds.
RATE_LIMIT_MAX_REQUESTS=
RATE_LIMIT_WINDOW_SECONDS=

# RC-2: PostgreSQL is the official development/production database.
# Example: postgresql://aipmo:aipmo@localhost:5432/aipmo
# After setting this, run: alembic upgrade head (creates schema + seeds
# Enterprise Domain data -- see docs/product/release-candidate/RC-2/).
# Unset -> falls back to sqlite:///./ai_pmo_copilot.db, kept only for quick
# local smoke-testing and for the test suite's isolated per-test databases;
# it is not a supported deployment target.
DATABASE_URL=

# Connection pool (Postgres only -- SQLite ignores these). See
# src/database/engine.py. Defaults shown are applied when unset.
# DB_POOL_SIZE=5
# DB_MAX_OVERFLOW=10
# DB_POOL_TIMEOUT_SECONDS=30
# DB_POOL_RECYCLE_SECONDS=1800
# DB_POOL_PRE_PING=true
