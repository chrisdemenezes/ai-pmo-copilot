# Backend FastAPI base URL, called server-side only (BFF -> backend).
BACKEND_URL=http://localhost:8000

# Same shared secret the backend expects as the X-API-Key header
# (see ../.env.example). Never exposed to the browser.
API_KEY=

# Shared workspace password (Nível 1 session, RFC-001) -- not per-user auth.
# Unset -> POST /api/bff/session always returns 503.
WORKSPACE_PASSWORD=

# HMAC secret used to sign the workspace session cookie. Generate with:
# openssl rand -base64 32
SESSION_SECRET=
