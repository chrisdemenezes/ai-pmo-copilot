# DPS-01 Demo Product Sprint — environment for the demo environment only.
# Not a new configuration surface: every variable below already exists in
# ../.env.example (backend) and ../web/.env.example (frontend). This file just
# collects the demo-specific values in one place so start-demo.sh has a single
# source to read from.
#
# Copy to demo/.env and fill in. demo/.env is gitignored (matches the existing
# ".env" rule in the root .gitignore).

# --- Backend (src/) ---
# "mock" cannot produce structured AI output today (see demo/README.md,
# "Impedimento conhecido"). Use "anthropic" + a real key for a working demo.
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
API_KEY=demo-local-secret-key

# --- Frontend (web/) ---
BACKEND_URL=http://localhost:8000
WORKSPACE_PASSWORD=demo-local-password
# Generate with: openssl rand -base64 32
SESSION_SECRET=
