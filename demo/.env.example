# DPS-01 Demo Product Sprint — environment for the demo environment only.
# Every variable below already exists in ../.env.example (backend) and
# ../web/.env.example (frontend), except MOCK_LLM_RESPONSE_FILE, which is the
# Demo Mode capability added in Sprint 2 (src/llm/providers/mock_provider.py) --
# an additive, opt-in field on the existing MockLLMProvider, not a new provider.
#
# Copy to demo/.env and fill in. demo/.env is gitignored (matches the existing
# ".env" rule in the root .gitignore).

# --- Backend (src/) ---
# Demo Mode: mock provider + a per-request response file, so the demo needs no
# external credential and no network call. seed_demo_data.py writes this file
# with each project's structured JSON before calling the real endpoint.
LLM_PROVIDER=mock
MOCK_LLM_RESPONSE_FILE=/tmp/ai-pmo-demo-mock-response.json
API_KEY=demo-local-secret-key

# To run the demo against real Claude instead of Demo Mode, set LLM_PROVIDER=anthropic
# and ANTHROPIC_API_KEY below -- seed_demo_data.py falls back to sending the raw
# project context instead of a canned response when Demo Mode isn't the active provider.
# ANTHROPIC_API_KEY=

# --- Frontend (web/) ---
BACKEND_URL=http://localhost:8000
WORKSPACE_PASSWORD=demo-local-password
# Generate with: openssl rand -base64 32
SESSION_SECRET=
